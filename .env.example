# Puerto HTTP del servidor Express.
PORT=4000

# Cadena de conexion de MongoDB.
# Vacio en desarrollo: se usa una instancia en memoria (mongodb-memory-server).
MONGODB_URI=

# Secreto para firmar los JWT. Obligatorio en produccion.
# Vacio en desarrollo: se usa un valor temporal no apto para produccion.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Credenciales de The Movie Database (v3 auth).
# https://developer.themoviedb.org
TMDB_API_KEY=
TMDB_LANG=es-ES
TMDB_IMAGE_BASE=https://image.tmdb.org/t/p

# Inserta titulos de demostracion cuando el catalogo esta vacio.
SEED_DEMO=true
