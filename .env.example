# Puerto del servidor
PORT=4000

# MongoDB. Si lo dejas vacio en desarrollo, se usa mongodb-memory-server (en RAM).
# En produccion (Railway/Atlas) pon tu cadena de conexion.
MONGODB_URI=

# JWT
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_EXPIRES_IN=7d

# TMDB (The Movie Database) — API externa de peliculas/series.
# Crea una cuenta gratis en https://www.themoviedb.org/settings/api
# y pega aqui tu API Key (v3 auth).
TMDB_API_KEY=
TMDB_LANG=es-ES
TMDB_IMAGE_BASE=https://image.tmdb.org/t/p
